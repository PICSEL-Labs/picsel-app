{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "types": ["nativewind/types"],
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strictNullChecks": false,
    "jsx": "react",
    "sourceMap": true,
    "typeRoots": ["src/@types/types"],
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@const/*": ["const/*"],
    }
  }
}
